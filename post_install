#!/usr/bin/env bash
set -euo pipefail

echo "[nodeManager] Post-install checks"

missing=0
for binary in node npm git; do
  if ! command -v "$binary" >/dev/null 2>&1; then
    echo "[nodeManager] Missing required binary: $binary"
    missing=1
  else
    echo "[nodeManager] Found $binary: $(command -v "$binary")"
  fi
done

if ! command -v pm2 >/dev/null 2>&1; then
  echo "[nodeManager] PM2 not found."
  if command -v npm >/dev/null 2>&1; then
    echo "[nodeManager] Installing PM2 globally with npm."
    npm install -g pm2
  else
    missing=1
  fi
else
  echo "[nodeManager] Found pm2: $(command -v pm2)"
fi

mkdir -p /home/cyberpanel/nodeManager
chmod 750 /home/cyberpanel/nodeManager || true

PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CYBERPANEL_ROOT="/usr/local/CyberCP"
HELPER_TARGET="$CYBERPANEL_ROOT/nodeManager/bin/node_manager_run_as_user"
STATIC_TARGET="$CYBERPANEL_ROOT/static/nodeManager"
STATIC_SOURCE=""

HELPER_SOURCE=""
for candidate in "$PLUGIN_DIR/bin/node_manager_run_as_user" "$PLUGIN_DIR/nodeManager/bin/node_manager_run_as_user" "$CYBERPANEL_ROOT/nodeManager/bin/node_manager_run_as_user"; do
  if [ -f "$candidate" ]; then
    HELPER_SOURCE="$candidate"
    break
  fi
done

if [ -n "$HELPER_SOURCE" ]; then
  echo "[nodeManager] Installing run-as-user helper to $HELPER_TARGET"
  mkdir -p "$(dirname "$HELPER_TARGET")"
  if [ "$HELPER_SOURCE" != "$HELPER_TARGET" ]; then
    cp -a "$HELPER_SOURCE" "$HELPER_TARGET"
  fi
  chown root:root "$HELPER_TARGET"
  chmod 750 "$HELPER_TARGET"
  if id lscpd >/dev/null 2>&1; then
    cat >/etc/sudoers.d/nodeManager <<EOF
Defaults:lscpd !requiretty
lscpd ALL=(root) NOPASSWD: $HELPER_TARGET
EOF
    chown root:root /etc/sudoers.d/nodeManager
    chmod 440 /etc/sudoers.d/nodeManager
    if command -v visudo >/dev/null 2>&1; then
      visudo -cf /etc/sudoers.d/nodeManager
    fi
    echo "[nodeManager] Installed sudoers rule for lscpd."
  else
    echo "[nodeManager] lscpd user not found; sudoers rule was not installed."
  fi
else
  echo "[nodeManager] Run-as-user helper not found. Checked:"
  echo "  $PLUGIN_DIR/bin/node_manager_run_as_user"
  echo "  $PLUGIN_DIR/nodeManager/bin/node_manager_run_as_user"
  echo "  $CYBERPANEL_ROOT/nodeManager/bin/node_manager_run_as_user"
fi

for candidate in "$PLUGIN_DIR/static/nodeManager" "$PLUGIN_DIR/nodeManager/static/nodeManager" "$CYBERPANEL_ROOT/static/nodeManager"; do
  if [ -d "$candidate" ]; then
    STATIC_SOURCE="$candidate"
    break
  fi
done

if [ -n "$STATIC_SOURCE" ]; then
  echo "[nodeManager] Installing static assets to $STATIC_TARGET"
  mkdir -p "$CYBERPANEL_ROOT/static"
  mkdir -p "$STATIC_TARGET"
  if [ "$STATIC_SOURCE" != "$STATIC_TARGET" ]; then
    cp -a "$STATIC_SOURCE/." "$STATIC_TARGET/"
  fi
  chown -R lscpd:lscpd "$STATIC_TARGET" 2>/dev/null || true
  ls -l "$STATIC_TARGET/nodeManager.css" "$STATIC_TARGET/nodeManager.js"
else
  echo "[nodeManager] Static source not found. Checked:"
  echo "  $PLUGIN_DIR/static/nodeManager"
  echo "  $PLUGIN_DIR/nodeManager/static/nodeManager"
  echo "  $CYBERPANEL_ROOT/static/nodeManager"
fi

if [ -x /usr/local/CyberCP/bin/python ] && [ -f /usr/local/CyberCP/manage.py ]; then
  echo "[nodeManager] Running Django migrations if plugin is installed as a Django app."
  /usr/local/CyberCP/bin/python /usr/local/CyberCP/manage.py migrate nodeManager || {
    echo "[nodeManager] Django migration failed. Use docs/INSTALLATION.md fallback SQL notes."
  }
else
  echo "[nodeManager] CyberPanel manage.py not found at expected path; skipping migrations."
fi

if [ "$missing" -eq 1 ]; then
  echo "[nodeManager] Install completed with missing prerequisites. Review the messages above."
  exit 1
fi

echo "[nodeManager] Post-install complete."
